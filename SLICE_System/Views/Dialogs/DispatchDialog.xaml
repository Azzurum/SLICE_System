<Window x:Class="SLICE_System.Views.Dialogs.DispatchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="Dispatch Stock" Height="580" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="BranchChipStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="border" Background="#F4F6F7" BorderBrush="#EAECEE" BorderThickness="1.5" CornerRadius="16" Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome x:Name="icon" Icon="MapMarker" Height="12" Foreground="#BDC3C7" Margin="0,0,6,0"/>
                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EAECEE"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E67E22"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#D35400"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="#BDC3C7" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>

        <Grid Margin="30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Dispatch Logistics" FontSize="24" FontWeight="Black" Foreground="#2C3E50"/>
                <TextBlock x:Name="txtItemName" Text="Preparing multi-item shipment" FontSize="13" Foreground="#7F8C8D" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="SELECT DESTINATIONS" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>

                <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icBranches">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding BranchName}" IsChecked="{Binding IsSelected}" Style="{StaticResource BranchChipStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,5,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ITEMS &amp; QUANTITIES" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>

                <Border Grid.Row="1" CornerRadius="8" BorderBrush="#EAECEE" BorderThickness="1" ClipToBounds="True">
                    <DataGrid x:Name="dgItems" AutoGenerateColumns="False" CanUserAddRows="False" 
                              GridLinesVisibility="Horizontal" Background="White" BorderThickness="0"
                              HeadersVisibility="Column" RowHeight="45">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8F9F9"/>
                                <Setter Property="Padding" Value="15,10"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#EAECEE"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="15,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="#F4F6F7" BorderThickness="0,0,0,1">
                                                <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#2C3E50"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ITEM" Binding="{Binding ItemName}" Width="*" IsReadOnly="True" Foreground="#2C3E50" FontWeight="Bold"/>
                            <DataGridTextColumn Header="UNIT" Binding="{Binding Unit}" Width="70" IsReadOnly="True" Foreground="#95A5A6"/>

                            <DataGridTemplateColumn Header="QTY / BRANCH" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#F4F6F7" CornerRadius="6" Height="32">
                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                     Background="Transparent" BorderThickness="0" 
                                                     FontWeight="Black" FontSize="14" Foreground="#E67E22"
                                                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="* Qty will be sent to EACH selected branch." Foreground="#E67E22" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="CANCEL" Click="Cancel_Click" Width="90" Height="42" Background="Transparent" BorderThickness="0" Foreground="#95A5A6" Cursor="Hand" FontWeight="Bold" Margin="0,0,10,0"/>

                <Button Grid.Column="2" Click="Dispatch_Click" Width="140" Height="42" Background="#E67E22" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Truck" Height="14" Foreground="White" Margin="0,0,8,0"/>
                        <TextBlock Text="DISPATCH"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>