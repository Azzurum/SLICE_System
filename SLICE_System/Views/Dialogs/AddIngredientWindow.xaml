<Window x:Class="SLICE_System.Views.Dialogs.AddIngredientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="Add Ingredient" Height="720" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Background" Value="#FAFCFC"/>
            <Setter Property="BorderBrush" Value="#EAECEE"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource ModernInput}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="#3498DB"/>
                                <Setter TargetName="bdr" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource ModernInput}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="35"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <ToggleButton Grid.Column="1" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <Path Data="M0,0 L5,5 L10,0" Stroke="#7F8C8D" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Grid Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border Background="White" BorderThickness="1" BorderBrush="#BDC3C7" CornerRadius="8" Margin="0,4,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="4"/>
                                            </Border.Effect>
                                            <ScrollViewer SnapsToDevicePixels="True" Padding="5">
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="BorderBrush" Value="#BDC3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" Margin="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="35" Color="#2C3E50" ShadowDepth="10" Opacity="0.25"/>
        </Border.Effect>

        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Background="#E8F8F5" Width="52" Height="52" CornerRadius="12" Margin="0,0,15,0">
                        <fa:ImageAwesome Icon="Leaf" Height="24" Foreground="#27AE60"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtHeaderTitle" Text="New Ingredient" FontSize="24" FontWeight="Black" Foreground="#2C3E50"/>
                        <TextBlock Text="Register a raw material to the Master Database." FontSize="13" Foreground="#95A5A6" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Click="Cancel_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top" Width="30" Height="30" ToolTip="Close">
                    <fa:ImageAwesome Icon="Close" Height="16" Foreground="#BDC3C7"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1">

                <Border Background="#FAFCFC" BorderBrush="#EAECEE" BorderThickness="1.5" CornerRadius="12" Padding="20" Margin="0,0,0,25">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="70" Height="70" Background="White" BorderBrush="#EAECEE" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                            <Grid>
                                <fa:ImageAwesome Icon="Image" Foreground="#D0D3D4" Height="24" VerticalAlignment="Center"/>
                                <Image x:Name="imgIngredient" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                            <TextBlock Text="INGREDIENT IMAGE" FontSize="11" FontWeight="Black" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                            <TextBlock Text="Upload a clear photo (.jpg, .png)" FontSize="12" FontWeight="SemiBold" Foreground="#BDC3C7"/>
                        </StackPanel>

                        <Button Grid.Column="2" Click="UploadIngredientImage_Click" Width="120" Height="42" Background="#F0F3F4" Foreground="#2C3E50" FontWeight="Bold" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="FolderOpen" Height="14" Foreground="#95A5A6" Margin="0,0,8,0"/>
                                <TextBlock Text="BROWSE" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Text="INGREDIENT NAME" FontSize="11" FontWeight="Black" Foreground="#95A5A6" Margin="4,0,0,8"/>
                <TextBox x:Name="txtName" Margin="0,0,0,20"/>

                <TextBlock Text="CATEGORY" FontSize="11" FontWeight="Black" Foreground="#95A5A6" Margin="4,0,0,8"/>
                <ComboBox x:Name="cmbCategory" Margin="0,0,0,30">
                    <ComboBoxItem Content="Dough &amp; Flour" IsSelected="True"/>
                    <ComboBoxItem Content="Cheese &amp; Dairy"/>
                    <ComboBoxItem Content="Meat &amp; Protein"/>
                    <ComboBoxItem Content="Sauce &amp; Spices"/>
                    <ComboBoxItem Content="Vegetables"/>
                    <ComboBoxItem Content="Beverages"/>
                    <ComboBoxItem Content="Packaging"/>
                </ComboBox>

                <Border Background="#FAFCFC" BorderBrush="#EAECEE" BorderThickness="1.5" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <fa:ImageAwesome Icon="BalanceScale" Height="16" Foreground="#3498DB" Margin="0,0,10,0"/>
                            <TextBlock Text="MEASUREMENT &amp; CONVERSION" FontSize="12" FontWeight="Black" Foreground="#2980B9"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PURCHASED AS (Bulk)" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D" Margin="4,0,0,8"/>
                                <TextBox x:Name="txtBulk" ToolTip="e.g., Sack, Box, Case"/>
                            </StackPanel>

                            <fa:ImageAwesome Grid.Column="1" Icon="ArrowRight" Height="14" Foreground="#BDC3C7" VerticalAlignment="Bottom" Margin="0,0,0,17"/>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="RECIPE UNIT (Base)" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D" Margin="4,0,0,8"/>
                                <ComboBox x:Name="cmbBase" ToolTip="Unit used in POS recipes">
                                    <ComboBoxItem Content="g" IsSelected="True"/>
                                    <ComboBoxItem Content="ml"/>
                                    <ComboBoxItem Content="pcs"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="CONVERSION RATIO (Base units per Bulk unit)" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D" Margin="4,0,0,8"/>
                        <TextBox x:Name="txtRatio" Text="1000" Foreground="#E67E22" FontWeight="Black"/>
                        <TextBlock Text="Example: 1 Sack = 25,000 g (Enter 25000)" FontSize="11" FontWeight="SemiBold" Foreground="#95A5A6" Margin="4,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Content="CANCEL" Click="Cancel_Click" Width="100" Height="48" Background="Transparent" BorderThickness="0" Foreground="#95A5A6" FontWeight="Bold" Cursor="Hand" Margin="0,0,15,0"/>

                <Button Click="Save_Click" Width="160" Height="48" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Check" Height="16" Foreground="White" Margin="0,0,10,0"/>
                        <TextBlock Text="SAVE ITEM" FontSize="14"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>