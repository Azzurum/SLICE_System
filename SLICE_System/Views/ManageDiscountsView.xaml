<UserControl x:Class="SLICE_System.Views.ManageDiscountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F4F6F7" FontFamily="Segoe UI">

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25" Margin="0,0,20,0" VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#BDC3C7" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <fa:ImageAwesome Icon="Tags" Height="20" Foreground="#E67E22" Margin="0,0,10,0"/>
                    <TextBlock Text="New Pricing Rule" FontSize="18" FontWeight="Black" Foreground="#2C3E50"/>
                </StackPanel>

                <TextBlock Text="PROMO / RULE NAME" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,5"/>
                <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" Margin="0,0,0,15" BorderBrush="#BDC3C7"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="RULE TYPE" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding DiscountTypes}" SelectedItem="{Binding NewType}" Height="40" Padding="10,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="REQUIRED ROLE" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding NewRole}" Height="40" Padding="10,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="VALUE TYPE" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding ValueTypes}" SelectedItem="{Binding NewValueType}" Height="40" Padding="10,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="AMOUNT / %" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>
                    </StackPanel>
                </Grid>

                <Button Command="{Binding SaveCommand}" Height="50" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Plus" Height="14" Foreground="White" Margin="0,0,8,0"/>
                        <TextBlock Text="CREATE RULE"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#BDC3C7" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Pricing Rules Registry" FontSize="20" FontWeight="Black" Foreground="#2C3E50" Margin="0,0,0,20"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding AdminDiscounts}" AutoGenerateColumns="False" IsReadOnly="True" 
                          HeadersVisibility="Column" RowHeight="50" BorderThickness="0" Background="Transparent" AlternatingRowBackground="#FAFCFC" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#ECF0F1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="RULE NAME" Binding="{Binding DiscountName}" Width="2*" FontWeight="Bold"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding DiscountType}" Width="*"/>

                        <DataGridTemplateColumn Header="VALUE" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DiscountValue}" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ValueType}" Value="Percentage">
                                                        <Setter Property="Text" Value="{Binding DiscountValue, StringFormat='{}{0:N0}%'}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ValueType}" Value="Fixed">
                                                        <Setter Property="Text" Value="{Binding DiscountValue, StringFormat='₱{0:N2}'}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="REQUIRED ROLE" Binding="{Binding RequiredRole}" Width="120" Foreground="#7F8C8D"/>

                        <DataGridTemplateColumn Header="STATUS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ToggleStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left">
                                        <Border CornerRadius="4" Padding="10,5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#D5F5E3"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Background" Value="#FDEDEC"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontWeight="Bold" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Text" Value="ACTIVE"/>
                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text" Value="INACTIVE"/>
                                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>