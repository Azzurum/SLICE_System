<UserControl x:Class="SLICE_System.Views.SubmitSuggestionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#1A0505" FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style TargetType="TextBox" x:Key="GlassTextBox">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="12" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Top"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="#2AFFFFFF"/>
                                <Setter Property="BorderBrush" Value="#E67E22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="True">

        <Canvas Opacity="0.6">
            <Canvas.Triggers>
                <EventTrigger RoutedEvent="Canvas.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="Glow1" Storyboard.TargetProperty="(Canvas.Top)" From="800" To="-400" Duration="0:0:25" AutoReverse="True"/>
                            <DoubleAnimation Storyboard.TargetName="Glow2" Storyboard.TargetProperty="(Canvas.Left)" From="1200" To="-200" Duration="0:0:35" AutoReverse="True"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Canvas.Triggers>

            <Ellipse x:Name="Glow1" Width="600" Height="600" Fill="#922B21" Opacity="0.3" Canvas.Left="200" Canvas.Top="800">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse x:Name="Glow2" Width="500" Height="500" Fill="#E67E22" Opacity="0.2" Canvas.Left="1200" Canvas.Top="200">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid x:Name="MainFormGrid">

            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Opacity" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSubmitted}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:0.4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="60,0,40,0">
                <fa:ImageAwesome Icon="QuoteLeft" Height="40" Foreground="#E67E22" HorizontalAlignment="Left" Margin="0,0,0,20" Opacity="0.5"/>
                <TextBlock Text="{Binding DynamicPrompt}" FontSize="42" FontWeight="Black" Foreground="White" TextWrapping="Wrap" LineHeight="48"/>
                <TextBlock Text="{Binding DynamicSubtext}" FontSize="16" Foreground="#95A5A6" TextWrapping="Wrap" Margin="0,15,0,0" LineHeight="24"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#B20A0202" BorderBrush="#20FFFFFF" BorderThickness="1,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="50" Color="Black" ShadowDepth="-10" Opacity="0.8"/>
                </Border.Effect>

                <Grid Margin="60">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="SUBMISSION FORM" FontSize="14" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,30"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,30">
                        <TextBlock Text="CATEGORY" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>
                        <ComboBox ItemsSource="{Binding SuggestionTypes}" SelectedItem="{Binding SelectedType}" 
                                  Height="50" FontSize="16" Padding="15,0" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,30">
                        <TextBlock Text="YOUR FEEDBACK" FontSize="12" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,10"/>
                        <TextBox Style="{StaticResource GlassTextBox}" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalAlignment="Stretch" Height="300"/>
                    </StackPanel>

                    <Button Grid.Row="3" Command="{Binding SubmitCommand}" Height="60" Background="#E67E22" Foreground="White" FontWeight="Black" FontSize="16" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TRANSMIT TO OWNER"/>
                            <fa:ImageAwesome Icon="PaperPlane" Height="16" Foreground="White" Margin="15,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="SuccessOverlay" Background="#F01A0505">

            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Opacity" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSubmitted}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.5" BeginTime="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4"/>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.4" Value="{x:Static Visibility.Collapsed}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="#20E67E22" Width="120" Height="120" CornerRadius="60" Margin="0,0,0,30">
                    <fa:ImageAwesome Icon="Check" Height="50" Foreground="#E67E22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <TextBlock Text="TRANSMISSION SUCCESSFUL" FontSize="28" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="The Owner has been notified." FontSize="16" Foreground="#95A5A6" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>