<UserControl x:Class="SLICE_System.Views.ReviewSuggestionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="White" FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="KanbanCard">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Command" Value="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="CommandParameter" Value="{Binding}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="CardBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="15">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" Color="#BDC3C7" ShadowDepth="2" Opacity="0.2"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="HoverTransform" Y="0"/>
                                </Border.RenderTransform>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Border Background="#F4F6F7" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding SuggestionType}" FontSize="11" FontWeight="Bold" Foreground="#34495E"/>
                                        </Border>
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold" Foreground="#BDC3C7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="{Binding Description}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" 
                                               MaxHeight="54" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,15" LineHeight="18"/>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Border Background="#EAECEE" Width="20" Height="20" CornerRadius="10" Margin="0,0,8,0">
                                            <fa:ImageAwesome Icon="User" Height="10" Foreground="#95A5A6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding SubmitterName}" FontSize="12" FontWeight="SemiBold" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                        <TextBlock Text=" • " FontSize="12" Foreground="#BDC3C7" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SubmittedDate, StringFormat='{}{0:MMM dd}'}" FontSize="11" Foreground="#95A5A6" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Width="4" HorizontalAlignment="Left" CornerRadius="8,0,0,8" Background="#BDC3C7" Opacity="0.3" Margin="0,0,0,0"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#FAFCFC"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverTransform" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid ClipToBounds="True">

        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Feedback Board" FontSize="26" FontWeight="Black" Foreground="#2C3E50"/>
                <TextBlock Text="Review, categorize, and act on suggestions from your customers." FontSize="14" Foreground="#95A5A6" Margin="0,2,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F4F6F7" CornerRadius="12" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,15">
                            <Border Background="#E74C3C" Width="8" Height="8" CornerRadius="4" Margin="0,0,8,0"/>
                            <TextBlock Text="PENDING TRIAGE" FontSize="13" FontWeight="Black" Foreground="#34495E"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" MinHeight="300">
                            <ItemsControl ItemsSource="{Binding PendingSuggestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource KanbanCard}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#F4F6F7" CornerRadius="12" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,15">
                            <Border Background="#F1C40F" Width="8" Height="8" CornerRadius="4" Margin="0,0,8,0"/>
                            <TextBlock Text="UNDER REVIEW" FontSize="13" FontWeight="Black" Foreground="#34495E"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" MinHeight="300">
                            <ItemsControl ItemsSource="{Binding UnderReviewSuggestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource KanbanCard}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="4" Background="#F4F6F7" CornerRadius="12" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,15">
                            <Border Background="#27AE60" Width="8" Height="8" CornerRadius="4" Margin="0,0,8,0"/>
                            <TextBlock Text="RESOLVED" FontSize="13" FontWeight="Black" Foreground="#34495E"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" MinHeight="300">
                            <ItemsControl ItemsSource="{Binding ResolvedSuggestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource KanbanCard}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border x:Name="DrawerDimmer" Background="#80000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Opacity" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.InputBindings>
                <MouseBinding Gesture="LeftClick" Command="{Binding CloseDrawerCommand}"/>
            </Border.InputBindings>
        </Border>

        <Border x:Name="DetailDrawer" HorizontalAlignment="Right" Width="480" Background="White" BorderThickness="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="50" Color="Black" ShadowDepth="-5" Opacity="0.2"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform X="500"/>
            </Border.RenderTransform>

            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="500" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock Text="Review Details" FontSize="20" FontWeight="Black" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <Button Command="{Binding CloseDrawerCommand}" Background="#F4F6F7" Width="32" Height="32" BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="16"/>
                            </Style>
                        </Button.Resources>
                        <fa:ImageAwesome Icon="Times" Height="14" Foreground="#7F8C8D"/>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="CATEGORY" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,8"/>
                        <Border Background="#EBF5FB" CornerRadius="6" Padding="12,8" HorizontalAlignment="Left" Margin="0,0,0,25">
                            <TextBlock Text="{Binding SelectedSuggestion.SuggestionType}" FontSize="13" FontWeight="Bold" Foreground="#2980B9"/>
                        </Border>

                        <TextBlock Text="CUSTOMER FEEDBACK" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,8"/>
                        <Border BorderBrush="#EAECEE" BorderThickness="4,0,0,0" Padding="15,5,0,5" Margin="0,0,0,35">
                            <TextBlock Text="{Binding SelectedSuggestion.Description}" TextWrapping="Wrap" FontSize="15" Foreground="#34495E" LineHeight="24"/>
                        </Border>

                        <TextBlock Text="EXECUTIVE DECISION NOTES" FontSize="11" FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}" Height="150" TextWrapping="Wrap" AcceptsReturn="True" 
                                 Padding="15" FontSize="14" Background="#F8F9F9" BorderBrush="#EAECEE" BorderThickness="1" Foreground="#2C3E50">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,25,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding ReviewCommand}" Height="50" Background="#F1C40F" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0" ToolTip="Mark as Under Review">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <fa:ImageAwesome Icon="Eye" Height="16" Foreground="White"/>
                    </Button>

                    <Button Grid.Column="2" Command="{Binding RejectCommand}" Height="50" Background="#E74C3C" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="REJECT"/>
                    </Button>

                    <Button Grid.Column="4" Command="{Binding ApproveCommand}" Height="50" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock Text="APPROVE"/>
                    </Button>
                </Grid>

                <Border x:Name="SuccessFlash" Grid.RowSpan="3" Background="#F5FFFFFF">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActionSuccess}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Background="#27AE60" Width="80" Height="80" CornerRadius="40" Margin="0,0,0,15">
                            <fa:ImageAwesome Icon="Check" Height="35" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="DECISION SAVED" FontSize="18" FontWeight="Black" Foreground="#27AE60" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

    </Grid>
</UserControl>