<UserControl x:Class="SLICE_System.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:views="clr-namespace:SLICE_System.Views"
             xmlns:vm="clr-namespace:SLICE_System.ViewModels"
             Background="#FDFBF7" FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="BrandOrange" Color="#E67E22"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextLight" Color="#95A5A6"/>

        <Style TargetType="ListBoxItem" x:Key="CategoryChipStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bdr" Background="White" CornerRadius="20" Margin="0,0,10,0" Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect Color="#BDC3C7" BlurRadius="5" Opacity="0.1" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter Margin="20,10" TextElement.FontWeight="Bold" TextElement.Foreground="#7F8C8D"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{StaticResource BrandOrange}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#FFF3E0"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandOrange}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bdr" Property="Background" Value="{StaticResource BrandOrange}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="MenuCardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,15,15"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="240"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect Color="#BDC3C7" BlurRadius="15" Opacity="0.3" ShadowDepth="4"/>
                            </Border.Effect>
                            <Grid>
                                <Border x:Name="OutOfStockBadge" Background="#E74C3C" CornerRadius="6" Padding="10,4" 
                                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0"
                                        Visibility="Collapsed" Panel.ZIndex="10">
                                    <TextBlock Text="OUT OF STOCK" Foreground="White" FontWeight="Black" FontSize="11"/>
                                </Border>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" CornerRadius="16,16,0,0" Background="White" ClipToBounds="True" BorderBrush="#F0F3F4" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <fa:ImageAwesome Icon="Cutlery" Foreground="#F5CBA7" Height="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                            <Image Source="{Binding ImagePath}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasImage}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="15,10,15,10">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="15" 
                                                   TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource TextDark}" 
                                                   Height="40" VerticalAlignment="Top"/>

                                        <TextBlock Text="{Binding SizeText}" FontSize="12" FontWeight="Black" Foreground="#95A5A6" 
                                                    HorizontalAlignment="Center" Margin="0,-5,0,5" 
                                                    Visibility="{Binding HasSize, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Border Background="{StaticResource BrandOrange}" CornerRadius="8" HorizontalAlignment="Center" Padding="15,5" Margin="0,0,0,0">
                                            <TextBlock Text="{Binding FormattedPrice}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsInStock}" Value="False">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter TargetName="bdr" Property="Opacity" Value="0.6"/>
                                <Setter TargetName="OutOfStockBadge" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="MinusBtnStyle">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#EAECEE"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#E74C3C"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="14" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#FDEDEC"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PlusBtnStyle">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#EAECEE"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#27AE60"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" CornerRadius="14" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#E8F8F5"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="#27AE60"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Counter" FontSize="32" FontWeight="Black" Foreground="{StaticResource TextDark}"/>
                    <TextBlock Text="Select items to add to the order." FontSize="16" Foreground="{StaticResource TextLight}"/>
                </StackPanel>

                <Border Grid.Column="1" Background="White" CornerRadius="10" Height="45" BorderBrush="#EAECEE" BorderThickness="1" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" Color="#BDC3C7" ShadowDepth="1" Opacity="0.15"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <fa:ImageAwesome Icon="Search" Height="14" Foreground="#95A5A6" HorizontalAlignment="Center"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" 
                                 BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" 
                                 FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" 
                                 ToolTip="Search Menu Items..."/>
                    </Grid>
                </Border>
            </Grid>

            <ListBox Grid.Row="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" 
                     Background="Transparent" BorderThickness="0" Margin="0,0,0,20"
                     ItemContainerStyle="{StaticResource CategoryChipStyle}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
                <ItemsControl ItemsSource="{Binding FilteredProducts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource MenuCardStyle}"
                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="1" Background="White" BorderBrush="#EEE" BorderThickness="1,0,0,0">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,10,0,20">
                    <TextBlock Text="Current Order" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    <TextBlock Text="{Binding CurrentDate, StringFormat='{}{0:MMMM dd, yyyy}'}" FontSize="12" Foreground="{StaticResource TextLight}"/>
                    <Separator Margin="0,20,0,0" Background="#F5F5F5"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" VerticalAlignment="Center" 
                                               FontWeight="SemiBold" Foreground="{StaticResource TextDark}" 
                                               TextWrapping="Wrap" Margin="0,0,10,0" FontSize="14"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Style="{StaticResource MinusBtnStyle}" 
                                                Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="—" FontSize="10" FontWeight="Bold" Margin="0,-1,0,0"/>
                                        </Button>

                                        <TextBlock Text="{Binding Qty}" Width="36" TextAlignment="Center" VerticalAlignment="Center" 
                                                   FontWeight="Black" FontSize="16" Foreground="{StaticResource TextDark}"/>

                                        <Button Style="{StaticResource PlusBtnStyle}" 
                                                Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="+" FontSize="16" FontWeight="Medium" Margin="0,-2,0,0"/>
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat='{}{0:N0}'}" 
                                               VerticalAlignment="Center" HorizontalAlignment="Right" 
                                               FontWeight="Bold" Foreground="{StaticResource TextDark}" FontSize="14"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Subtotal:" FontSize="14" Foreground="{StaticResource TextLight}"/>
                        <TextBlock Text="{Binding SubTotal, StringFormat='₱{0:N2}'}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,0,0,15" Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Discount:" FontSize="14" Foreground="#E74C3C"/>
                            <Border Background="#FDEDEC" CornerRadius="4" Padding="5,2" Margin="10,0,0,0">
                                <TextBlock Text="{Binding ActiveDiscount.DiscountName}" FontSize="11" Foreground="#E74C3C" FontWeight="Bold"/>
                            </Border>
                            <Button Command="{Binding RemoveDiscountCommand}" Background="Transparent" BorderThickness="0" Margin="5,0,0,0" Cursor="Hand" ToolTip="Remove Discount">
                                <fa:ImageAwesome Icon="Times" Height="10" Foreground="#95A5A6"/>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding DiscountAmount, StringFormat='-₱{0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="#E74C3C" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Margin="0,0,0,25">
                        <TextBlock Text="Total Due" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextLight}" VerticalAlignment="Bottom"/>
                        <TextBlock Text="{Binding GrandTotal, StringFormat='₱{0:N2}'}" FontSize="32" FontWeight="Black" Foreground="{StaticResource TextDark}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding OpenDiscountCommand}" Height="60" Background="#F1C40F" Foreground="White" Cursor="Hand" BorderThickness="0" ToolTip="Apply Discount">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>
                            <fa:ImageAwesome Icon="Tags" Height="24" Foreground="White"/>
                        </Button>

                        <Button Grid.Column="2" Content="PLACE ORDER" Command="{Binding CheckoutCommand}" Height="60" Background="{StaticResource BrandOrange}" Foreground="White" FontSize="18" FontWeight="Black" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <Button Command="{Binding ClearCartCommand}" Margin="0,15,0,0" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Trash" Foreground="#E74C3C" Height="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Clear Order" Foreground="#E74C3C" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="AnimationOverlay" Visibility="{Binding IsCooking, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#D9FFFFFF"/>
            <views:CookingAnimationView/>
        </Grid>
    </Grid>
</UserControl>